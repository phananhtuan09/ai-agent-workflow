# Project-owned defaults for verify-runtime.
# Keep secrets out of this tracked file.
# Put secret values in the process environment variables named below.

E2E_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:3000/api
E2E_HEALTHCHECK_URL=http://localhost:3000

# Leave empty when the project is started outside the verification workflow.
E2E_START_COMMAND=
E2E_START_TIMEOUT_SECONDS=60

E2E_DESKTOP_VIEWPORT=1440x900
E2E_MOBILE_VIEWPORT=390x844
E2E_ARTIFACT_DIR=docs/ai/verifications/e2e-artifacts

# Non-secret account identifiers may be set per project.
E2E_ACCOUNT_USERNAME=
E2E_ACCOUNT_EMAIL=

# These values are names of process environment variables, not secrets.
E2E_ACCOUNT_PASSWORD_ENV=E2E_ACCOUNT_PASSWORD
E2E_API_KEY_ENV=E2E_API_KEY

E2E_SETUP_NOTES=
