{
  "id": "feature-standard",
  "name": "Feature Standard",
  "description": "Workflow chuẩn mới cho feature: spec, execute, sync spec, verify.",
  "steps": [
    {
      "id": "spec",
      "title": "Create spec",
      "type": "command",
      "value": "/spec",
      "hint": "Gõ /spec \"mô tả feature\""
    },
    {
      "id": "review-spec",
      "title": "Review spec",
      "type": "sub-agent",
      "value": "/review-spec",
      "hint": "Gõ /review-spec @docs/ai/specs/<file>.md"
    },
    {
      "id": "execute-spec",
      "title": "Execute spec",
      "type": "command",
      "value": "/execute-spec",
      "hint": "Gõ /execute-spec @docs/ai/specs/<file>.md"
    },
    {
      "id": "sync-spec",
      "title": "Sync spec",
      "type": "command",
      "value": "/sync-spec",
      "hint": "Gõ /sync-spec @docs/ai/specs/<file>.md"
    },
    {
      "id": "verify-feature",
      "title": "Verify feature",
      "type": "skill",
      "value": "verify-feature",
      "hint": "Yêu cầu agent verify feature theo latest synced spec"
    }
  ]
}
